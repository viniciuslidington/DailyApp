# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Web Push (VAPID) — generate with `npx web-push generate-vapid-keys`
# NEXT_PUBLIC_ prefix exposes the public key to the browser (Next.js build).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Edge function secrets — set via `supabase secrets set KEY=value`
# VAPID_PUBLIC_KEY must equal NEXT_PUBLIC_VAPID_PUBLIC_KEY (same key, different name)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=  (same as above)
# VAPID_SUBJECT=      (same as above)
